MONGO_URI=mongodb+srv://<db_user>:<url_encoded_password>@crowdraise.cf7hsxx.mongodb.net/<database_name>?retryWrites=true&w=majority&appName=Crowdraise
JWT_KEY=replace_with_a_strong_random_secret
PORT=3000
NODE_ENV=development

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Default 'onboarding@resend.dev' works for testing if you send to your registered email.
# To send to any user, use a custom verified domain on Resend.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# ── Platform Fees ─────────────────────────────────────────────────────────────
# Fee rates are defined in routes/contributions.js (PLATFORM_FEE_RATES).
# Current rates: fundraiser=1%, occasion=3%, tips=3%
# Fees are calculated at contribution initialization and stored in the DB.
# netAmount = amount paid by donor minus platformFee.
